{
  "name": "datagrizard",
  "version": "0.1.0",
  "description": "A trustworthy, domain-neutral analytical control plane and DataGrid for React agents and applications, built on TanStack Table v8.",
  "type": "module",
  "license": "MIT",
  "author": "Nathaniel Lyman <nathaniel.lyman@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nathaniel-lyman/DataGrizard.git"
  },
  "bugs": {
    "url": "https://github.com/nathaniel-lyman/DataGrizard/issues"
  },
  "homepage": "https://github.com/nathaniel-lyman/DataGrizard#readme",
  "keywords": [
    "react",
    "datagrid",
    "data-grid",
    "table",
    "pivot",
    "tanstack-table",
    "grouping",
    "virtualization",
    "typescript"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/datagrid.cjs",
  "module": "./dist/datagrid.js",
  "types": "./dist/datagrid.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/datagrid.d.ts",
        "default": "./dist/datagrid.js"
      },
      "require": {
        "types": "./dist/datagrid.d.cts",
        "default": "./dist/datagrid.cjs"
      }
    },
    "./styles.css": "./dist/datagrid.css",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "clean:dist": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:css": "esbuild src/components/DataGrid/datagrid.css --minify --outfile=dist/datagrid.css",
    "build:package": "npm run clean:dist && npm run build:lib && npm run build:css",
    "preview": "vite preview --host 127.0.0.1",
    "server": "tsx --tsconfig tsconfig.app.json server/retailBigQueryServer.ts",
    "export:mock": "tsx --tsconfig tsconfig.app.json scripts/exportMockRows.ts",
    "test": "vitest run",
    "test:package": "npm run build:package && node scripts/verify-package.mjs"
  },
  "peerDependencies": {
    "@tanstack/react-table": "^8.21.3",
    "react": "^18.2 || ^19",
    "react-dom": "^18.2 || ^19"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@google-cloud/bigquery": "^7.9.0",
    "@microsoft/api-extractor": "^7.58.9",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.1",
    "express": "^5.1.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "postcss-selector-parser": "^7.1.4",
    "publint": "^0.3.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  }
}
